{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apievangelist.com/amazon-app-runner/service",
  "title": "AWS App Runner Service",
  "description": "Schema defining the structure of an AWS App Runner service resource, including source configuration, instance configuration, networking, auto scaling, health checks, and observability settings.",
  "type": "object",
  "required": [
    "ServiceName",
    "SourceConfiguration"
  ],
  "properties": {
    "ServiceName": {
      "type": "string",
      "description": "The customer-provided service name.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9-_]{3,39}$"
    },
    "ServiceId": {
      "type": "string",
      "description": "An ID that App Runner generated for this service."
    },
    "ServiceArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the service."
    },
    "ServiceUrl": {
      "type": "string",
      "description": "A subdomain URL for the App Runner service."
    },
    "Status": {
      "type": "string",
      "enum": [
        "CREATE_FAILED",
        "RUNNING",
        "DELETED",
        "DELETE_FAILED",
        "PAUSED",
        "OPERATION_IN_PROGRESS"
      ],
      "description": "The current state of the App Runner service."
    },
    "SourceConfiguration": {
      "$ref": "#/$defs/SourceConfiguration"
    },
    "InstanceConfiguration": {
      "$ref": "#/$defs/InstanceConfiguration"
    },
    "AutoScalingConfigurationSummary": {
      "$ref": "#/$defs/AutoScalingConfigurationSummary"
    },
    "HealthCheckConfiguration": {
      "$ref": "#/$defs/HealthCheckConfiguration"
    },
    "NetworkConfiguration": {
      "$ref": "#/$defs/NetworkConfiguration"
    },
    "ObservabilityConfiguration": {
      "$ref": "#/$defs/ServiceObservabilityConfiguration"
    },
    "CreatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "The time when the service was created."
    },
    "UpdatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "The time when the service was last updated."
    }
  },
  "$defs": {
    "SourceConfiguration": {
      "type": "object",
      "description": "Describes the source deployed to the App Runner service.",
      "properties": {
        "CodeRepository": {
          "type": "object",
          "properties": {
            "RepositoryUrl": {
              "type": "string"
            },
            "SourceCodeVersion": {
              "type": "object",
              "properties": {
                "Type": {
                  "type": "string",
                  "enum": [
                    "BRANCH"
                  ]
                },
                "Value": {
                  "type": "string"
                }
              }
            },
            "CodeConfiguration": {
              "type": "object"
            }
          }
        },
        "ImageRepository": {
          "type": "object",
          "properties": {
            "ImageIdentifier": {
              "type": "string"
            },
            "ImageRepositoryType": {
              "type": "string",
              "enum": [
                "ECR",
                "ECR_PUBLIC"
              ]
            },
            "ImageConfiguration": {
              "type": "object"
            }
          }
        },
        "AutoDeploymentsEnabled": {
          "type": "boolean",
          "description": "Whether continuous integration from the source repository is enabled."
        },
        "AuthenticationConfiguration": {
          "type": "object",
          "properties": {
            "ConnectionArn": {
              "type": "string"
            },
            "AccessRoleArn": {
              "type": "string"
            }
          }
        }
      }
    },
    "InstanceConfiguration": {
      "type": "object",
      "description": "Describes the runtime configuration of an App Runner service instance.",
      "properties": {
        "Cpu": {
          "type": "string",
          "description": "The number of CPU units reserved for each instance.",
          "enum": [
            "256",
            "512",
            "1024",
            "2048",
            "4096"
          ]
        },
        "Memory": {
          "type": "string",
          "description": "The amount of memory, in MB, reserved for each instance.",
          "enum": [
            "512",
            "1024",
            "2048",
            "3072",
            "4096",
            "6144",
            "8192",
            "10240",
            "12288"
          ]
        },
        "InstanceRoleArn": {
          "type": "string",
          "description": "The ARN of an IAM role that provides permissions to the App Runner service."
        }
      }
    },
    "AutoScalingConfigurationSummary": {
      "type": "object",
      "description": "Summary of an auto scaling configuration.",
      "properties": {
        "AutoScalingConfigurationArn": {
          "type": "string"
        },
        "AutoScalingConfigurationName": {
          "type": "string"
        },
        "AutoScalingConfigurationRevision": {
          "type": "integer"
        }
      }
    },
    "HealthCheckConfiguration": {
      "type": "object",
      "description": "Describes the health check configuration for the service.",
      "properties": {
        "Protocol": {
          "type": "string",
          "enum": [
            "TCP",
            "HTTP"
          ]
        },
        "Path": {
          "type": "string"
        },
        "Interval": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "Timeout": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "HealthyThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "UnhealthyThreshold": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        }
      }
    },
    "NetworkConfiguration": {
      "type": "object",
      "description": "Describes the networking configuration for the service.",
      "properties": {
        "EgressConfiguration": {
          "type": "object",
          "properties": {
            "EgressType": {
              "type": "string",
              "enum": [
                "DEFAULT",
                "VPC"
              ]
            },
            "VpcConnectorArn": {
              "type": "string"
            }
          }
        },
        "IngressConfiguration": {
          "type": "object",
          "properties": {
            "IsPubliclyAccessible": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "ServiceObservabilityConfiguration": {
      "type": "object",
      "description": "Describes the observability configuration of the service.",
      "properties": {
        "ObservabilityEnabled": {
          "type": "boolean"
        },
        "ObservabilityConfigurationArn": {
          "type": "string"
        }
      }
    }
  }
}
